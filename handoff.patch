+export function detectMimeTypeFromBase64(
+  base64?: string,
+  fallback = "image/jpeg"
+) {
+  if (!base64) return fallback;
+  if (base64.startsWith("/9j/")) return "image/jpeg";
+  if (base64.startsWith("iVBOR")) return "image/png";
+  if (base64.startsWith("UklGR")) return "image/webp";
