          </div>
          <input
            type="file"
            accept="image/*"
            multiple
            className="hidden"
            onChange={(e) => onAddFiles(e.target.files)}
          />
        </label>

        <button
          type="button"
          onClick={onClearAll}
          className="px-4 py-3 border rounded-xl text-sm text-gray-700"
        >
