            <div className="pt-3">
              <div className="mb-3 flex items-center justify-between">
                <div className="text-sm font-medium text-gray-700">
                  최근 생성/업로드된 모델 얼굴
                </div>
                <button
                  type="button"
                  onClick={() => setMode("upload")}
                  className="text-xs text-gray-500 underline underline-offset-2"
                >
                  전체 목록 보기
